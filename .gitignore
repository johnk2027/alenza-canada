# Local database and generated files
alenza_data/*.db
alenza_data/*.sqlite
alenza_data/*.sqlite3
alenza_data/documents/*
alenza_data/backups/*
alenza_data/exports/*

# Keep folders
!alenza_data/documents/.gitkeep
!alenza_data/backups/.gitkeep
!alenza_data/exports/.gitkeep

# Catch accidental root-level databases
*.db
*.sqlite
*.sqlite3

# Secrets
.streamlit/secrets.toml
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store
Thumbs.db
